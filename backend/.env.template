# RBSL × Meximco E-Commerce Platform - Production Environment Template

### 1. Database Configuration
# Main PostgreSQL connection string (Supabase/Neon/Local)
DATABASE_URL=
DB_NAME=medusa-v2

### 2. Security & Authentication (CRITICAL)
# Must be unique, long strings. Produciton will FAIL if missing.
JWT_SECRET=
COOKIE_SECRET=

### 3. Redis Infrastructure
# Required for rate-limiting and background jobs
REDIS_URL=redis://localhost:6379

### 4. CORS & Access Control
# Comma-separated lists of allowed origins
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

### 5. Supabase Integration (Storage)
SUPABASE_URL=
SUPABASE_KEY=

### 6. Email (Resend)
RESEND_API_KEY=

### 7. Frontend Specific (Next.js)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_DEFAULT_REGION=us
